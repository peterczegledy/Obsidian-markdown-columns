{
  "compilerOptions": {
    "paths": {
      "obsidian": [
        "./node_modules/obsidian"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/obsidian"
    ],
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "es6",
    "allowJs": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strict": true
  },
  "include": [
    "**/*.ts"
  ]
}